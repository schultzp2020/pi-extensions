{
  "name": "@schultzp2020/pi-cursor",
  "version": "0.1.4",
  "description": "Pi extension for Cursor subscription models via local OpenAI-compatible proxy",
  "keywords": [
    "cursor",
    "extension",
    "openai",
    "pi",
    "pi-package",
    "proxy"
  ],
  "license": "MIT",
  "author": "Paul Schultz",
  "repository": {
    "type": "git",
    "url": "https://github.com/schultzp2020/pi-extensions.git",
    "directory": "packages/pi-cursor"
  },
  "files": [
    "dist/",
    "proto/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "generate": "npx @bufbuild/buf generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --type-check --deny-warnings .",
    "lint:fix": "oxlint --type-aware --type-check --fix .",
    "prepare": "husky",
    "build": "rolldown --config rolldown.config.ts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.0.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.50.0",
    "@bufbuild/protoc-gen-es": "^2.10.0",
    "@mariozechner/pi-ai": "^0.71.1",
    "@mariozechner/pi-coding-agent": "^0.71.1",
    "@types/node": "^22.0.0",
    "rolldown": "^1.0.0-rc.18",
    "typescript": "^5.9.0",
    "vitest": "^4.1.5"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
